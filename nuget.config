      <certificate
        fingerprint="1F4B311D9ACC115C8DC8018B5A49E00FCE6DA8E2855F9F014CA6F34570BC482D"
        hashAlgorithm="SHA256"
        allowUntrustedRoot="false" />
    </author>
  </trustedSigners>
</configuration>
