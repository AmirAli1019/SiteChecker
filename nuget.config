<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- 1. Package sources – only your mirror -->
  <packageSources>
    <clear />
    <add key="megan" value="https://hub.megan.ir/nuget/index.json" />
    <!-- <add key="Chabokan" value="https://mirror2.chabokan.net/nuget/v3/index.json" /> -->
  </packageSources>

  <!-- 2. Disable all other package sources -->
  <disabledPackageSources>
